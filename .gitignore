# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/

# Data directories (the Luthey-Schulten repo is big; re-clone it rather than
# commit it)
data/
!data/.gitkeep

# Outputs and caches
outputs/*.csv
outputs/*.png
outputs/*.tmp
outputs/.wt_*.pkl
*.log
*.tmp

# Secrets — never commit any of these
.env
.env.*
*.pem
*.key
*credentials*
*secret*
*token*
.github_token
gh_token.txt

# IDE
.vscode/
.idea/
.DS_Store

# Jupyter
.ipynb_checkpoints/

# memory_bank auto-generated indexes (rebuilt by check.py)
memory_bank/index/*.sqlite
memory_bank/index/*.faiss
memory_bank/index/concept_graph.json

# Local patch backups (not for the remote)
patches/

# Rust build artifacts (cell_sim_rust)
cell_sim_rust/target/
cell_sim_rust/Cargo.lock
