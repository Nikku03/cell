# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/

# Luthey-Schulten input data (the upstream repo is ~1.8 MB binary; re-stage
# it rather than redistribute - see memory_bank/data/STAGING.md). Narrowly
# scoped - do NOT use a bare `data/` pattern because that would also ignore
# memory_bank/data/*.csv (the small derived reference tables we DO commit).
cell_sim/data/Minimal_Cell_ComplexFormation/

# Outputs and caches
outputs/*.csv
outputs/*.png
outputs/*.tmp
outputs/.wt_*.pkl
*.log
*.tmp

# Secrets — never commit any of these
.env
.env.*
*.pem
*.key
*credentials*
*secret*
*token*
.github_token
gh_token.txt

# IDE
.vscode/
.idea/
.DS_Store

# Jupyter
.ipynb_checkpoints/

# memory_bank auto-generated indexes (rebuilt by check.py)
memory_bank/index/*.sqlite
memory_bank/index/*.faiss
memory_bank/index/concept_graph.json

# Local patch backups (not for the remote)
patches/

# Rust build artifacts (cell_sim_rust)
cell_sim_rust/target/
cell_sim_rust/Cargo.lock

# Feature cache — contains per-gene pretrained-model embeddings, usually
# large parquet files. Only the manifest (for integrity tracking) and
# the .gitkeep (so the empty cache dir survives) are tracked.
cell_sim/features/cache/*
!cell_sim/features/cache/manifest.json
!cell_sim/features/cache/.gitkeep
